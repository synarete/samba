		smbprofile_stats_basic NT_transact_rename_stats;
		smbprofile_stats_basic NT_transact_query_security_desc_stats;
		smbprofile_stats_basic NT_transact_get_user_quota_stats;
		smbprofile_stats_basic NT_transact_set_user_quota_stats;
		/* SMB2 */
		smbprofile_stats_iobytes smb2_negprot_stats;
		smbprofile_stats_iobytes smb2_sesssetup_stats;
		smbprofile_stats_iobytes smb2_logoff_stats;
		smbprofile_stats_iobytes smb2_tcon_stats;
		smbprofile_stats_iobytes smb2_tdis_stats;
		smbprofile_stats_iobytes smb2_create_stats;
		smbprofile_stats_iobytes smb2_close_stats;
		smbprofile_stats_iobytes smb2_flush_stats;
		smbprofile_stats_iobytes smb2_read_stats;
		smbprofile_stats_iobytes smb2_write_stats;
		smbprofile_stats_iobytes smb2_lock_stats;
		smbprofile_stats_iobytes smb2_ioctl_stats;
		smbprofile_stats_iobytes smb2_cancel_stats;
		smbprofile_stats_iobytes smb2_keepalive_stats;
		smbprofile_stats_iobytes smb2_find_stats;
		smbprofile_stats_iobytes smb2_notify_stats;
		smbprofile_stats_iobytes smb2_getinfo_stats;
		smbprofile_stats_iobytes smb2_setinfo_stats;
		smbprofile_stats_iobytes smb2_break_stats;
	} smbprofile_values;

	/*
	 * Main profile statistics structure
	 * This is the top-level structure that contains all profiling data
	 */
	typedef [public] struct {
		hyper                     magic;
		boolean8                  summary_record;
		smbprofile_version_values version;
		smbprofile_values         values;
	} profile_stats;
}
