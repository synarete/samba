#include "idl_types.h"

/*
 * SMB Profile Statistics IDL
 *
 * Profiling data structures for Samba's smbprofile infrastructure via IDL
 *
 * Copyright (C) Samba Team 2026
 */

[
	pointer_default(unique),
	version(0.0),
	helpstring("smbprofile structures")
]
interface smbprofile
{
	typedef [v1_enum] enum {
		 /*
		 * NOTE: Version 0 is designed to be unstable and the format
		 * may change during development.
		 */
		SMBPROFILE_VERSION_0 = 0x00000000
	} smbprofile_version_values;

	const uint32 SMBPROFILE_VERSION_CURRENT = SMBPROFILE_VERSION_0;

	typedef [public] struct {
		hyper count; /* number of events */
	} smbprofile_stats_count;

	typedef [public] struct {
		hyper time;  /* cumulative time in microseconds */
	} smbprofile_stats_time;

	typedef [public] struct {
		hyper count; /* number of events */
		hyper time;  /* microseconds */
	} smbprofile_stats_basic;

	typedef [public] struct {
		hyper count; /* number of events */
		hyper time;  /* microseconds */
		hyper idle;  /* idle time in microseconds */
		hyper bytes;
	} smbprofile_stats_bytes;

	typedef [public] struct {
		hyper count;        /* number of events */
		hyper failed_count; /* number of unsuccessful events */
		hyper time;         /* microseconds */
		hyper buckets[10];  /* latency: 1,2,4,8,...256,Inf msecs */
		hyper idle;         /* idle time in microseconds */
		hyper inbytes;      /* bytes read */
		hyper outbytes;     /* bytes written */
	} smbprofile_stats_iobytes;

	typedef [public] struct {
		hyper start; /* start time, microseconds */
		smbprofile_stats_time *stats;
	} smbprofile_stats_time_async;

	typedef [public] struct {
		hyper start; /* start time, microseconds */
		smbprofile_stats_basic *stats;
	} smbprofile_stats_basic_async;

	typedef [public] struct {
		hyper start;
		hyper idle_start;
		hyper idle_time;
		smbprofile_stats_bytes *stats;
	} smbprofile_stats_bytes_async;

	typedef [public] struct {
		hyper start;
		hyper idle_start;
		hyper idle_time;
		smbprofile_stats_iobytes *stats;
	} smbprofile_stats_iobytes_async;

	/*
	 * Global statistics section
	 */
	typedef [public] struct {
		smbprofile_stats_count connect_stats;
		smbprofile_stats_count disconnect_stats;
		smbprofile_stats_basic idle_stats;
		smbprofile_stats_time cpu_user_stats;
		smbprofile_stats_time cpu_system_stats;
		smbprofile_stats_count request_stats;
		smbprofile_stats_basic push_sec_ctx_stats;
		smbprofile_stats_basic set_sec_ctx_stats;
		smbprofile_stats_basic set_root_sec_ctx_stats;
		smbprofile_stats_basic pop_sec_ctx_stats;
		smbprofile_stats_count num_sessions_stats;
		smbprofile_stats_count num_tcons_stats;
		smbprofile_stats_count num_files_stats;
	} smbprofile_global_stats;

	/*
	 * Authentication statistics section
	 */
	typedef [public] struct {
		smbprofile_stats_count authentication_stats;
		smbprofile_stats_count authentication_failed_stats;
	} smbprofile_auth_stats;

	/*
	 * System call statistics section
	 */
	typedef [public] struct {
		smbprofile_stats_basic syscall_opendir_stats;
		smbprofile_stats_basic syscall_fdopendir_stats;
		smbprofile_stats_basic syscall_readdir_stats;
		smbprofile_stats_basic syscall_rewinddir_stats;
		smbprofile_stats_basic syscall_mkdirat_stats;
		smbprofile_stats_basic syscall_closedir_stats;
		smbprofile_stats_basic syscall_open_stats;
		smbprofile_stats_basic syscall_openat_stats;
		smbprofile_stats_basic syscall_createfile_stats;
		smbprofile_stats_basic syscall_close_stats;
		smbprofile_stats_bytes syscall_pread_stats;
		smbprofile_stats_bytes syscall_asys_pread_stats;
		smbprofile_stats_bytes syscall_pwrite_stats;
		smbprofile_stats_bytes syscall_asys_pwrite_stats;
		smbprofile_stats_basic syscall_lseek_stats;
		smbprofile_stats_bytes syscall_sendfile_stats;
		smbprofile_stats_bytes syscall_recvfile_stats;
		smbprofile_stats_basic syscall_renameat_stats;
		smbprofile_stats_basic syscall_rename_stream_stats;
		smbprofile_stats_bytes syscall_asys_fsync_stats;
		smbprofile_stats_basic syscall_stat_stats;
		smbprofile_stats_basic syscall_fstat_stats;
		smbprofile_stats_basic syscall_lstat_stats;
		smbprofile_stats_basic syscall_fstatat_stats;
		smbprofile_stats_basic syscall_get_alloc_size_stats;
		smbprofile_stats_basic syscall_unlinkat_stats;
		smbprofile_stats_basic syscall_chmod_stats;
		smbprofile_stats_basic syscall_fchmod_stats;
		smbprofile_stats_basic syscall_fchown_stats;
		smbprofile_stats_basic syscall_lchown_stats;
		smbprofile_stats_basic syscall_chdir_stats;
		smbprofile_stats_basic syscall_fntimes_stats;
		smbprofile_stats_basic syscall_ftruncate_stats;
		smbprofile_stats_basic syscall_fallocate_stats;
		smbprofile_stats_basic syscall_fcntl_lock_stats;
		smbprofile_stats_basic syscall_fcntl_stats;
		smbprofile_stats_basic syscall_linux_setlease_stats;
		smbprofile_stats_basic syscall_fcntl_getlock_stats;
		smbprofile_stats_basic syscall_readlinkat_stats;
		smbprofile_stats_basic syscall_symlinkat_stats;
		smbprofile_stats_basic syscall_linkat_stats;
		smbprofile_stats_basic syscall_mknodat_stats;
		smbprofile_stats_basic syscall_realpath_stats;
		smbprofile_stats_basic syscall_get_quota_stats;
		smbprofile_stats_basic syscall_set_quota_stats;
		smbprofile_stats_basic syscall_get_sd_stats;
		smbprofile_stats_basic syscall_set_sd_stats;
		smbprofile_stats_basic syscall_brl_lock_stats;
		smbprofile_stats_basic syscall_brl_unlock_stats;
		smbprofile_stats_basic syscall_brl_cancel_stats;
		smbprofile_stats_bytes syscall_asys_getxattrat_stats;
		smbprofile_stats_basic syscall_fgetxattr_stats;
		smbprofile_stats_basic syscall_flistxattr_stats;
		smbprofile_stats_basic syscall_fremovexattr_stats;
		smbprofile_stats_basic syscall_fsetxattr_stats;
		smbprofile_stats_basic syscall_fstatvfs_stats;
	} smbprofile_syscall_stats;

	/*
	 * ACL call statistics section
	 */
	typedef [public] struct {
		smbprofile_stats_basic get_nt_acl_stats;
		smbprofile_stats_basic get_nt_acl_at_stats;
		smbprofile_stats_basic fget_nt_acl_stats;
		smbprofile_stats_basic fset_nt_acl_stats;
	} smbprofile_acl_stats;

	/*
	 * Stat cache statistics section
	 */
	typedef [public] struct {
		smbprofile_stats_count statcache_lookups_stats;
		smbprofile_stats_count statcache_misses_stats;
		smbprofile_stats_count statcache_hits_stats;
	} smbprofile_statcache_stats;

